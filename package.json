{
  "name": "dout.dev",
  "version": "0.1.1",
  "description": "The DoUtDev Blog - Static site generator with custom CMS and template engine",
  "repository": "git@github.com:pixu1980/dout-dev.git",
  "author": "Emiliano \"Pixu\" Pisu",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --import ./scripts/register-bundle-text-hooks.js --test \"**/*.test.js\"",
    "test:coverage": "node --import ./scripts/register-bundle-text-hooks.js --test --experimental-test-coverage --test-coverage-exclude='**/*.test.js' \"**/*.test.js\"",
    "test:watch": "node --import ./scripts/register-bundle-text-hooks.js --test --watch \"**/*.test.js\"",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "lint": "node scripts/lint.js",
    "format": "node scripts/format.js",
    "format:build": "pnpm -s biome format --write . && pnpm format:html",
    "format:check": "node scripts/format-check.js",
    "format:check:build": "pnpm -s biome format --reporter=summary --diagnostic-level=error . && pnpm format:check:html",
    "format:html": "node scripts/linting/format-html.js",
    "format:css": "pnpm -s prettier --write \"src/styles/**/*.css\"",
    "format:check:css": "pnpm -s prettier --check --write \"src/styles/**/*.css\"",
    "format:generated": "pnpm -s prettier --write \"tests/example/*.html\" && pnpm -s biome format \"scripts/**/*.js\" \"tests/**/*.cjs\"",
    "format:check:html": "node scripts/linting/format-check-html.js",
    "validate:html": "node scripts/linting/validate-html.js",
    "validate:structure": "node scripts/linting/validate-structure.js",
    "validate:links": "node scripts/linting/validate-links.js",
    "validate:links:dist": "node scripts/linting/validate-links.js dist",
    "validate:a11y": "node scripts/linting/validate-a11y.js",
    "validate:security": "node scripts/linting/validate-security.js",
    "validate:opengraph": "node scripts/linting/validate-opengraph.js",
    "validate:opengraph:dist": "node scripts/linting/validate-opengraph.js dist",
    "validate:all": "pnpm validate:html && pnpm validate:structure && pnpm validate:links && pnpm validate:a11y && pnpm validate:opengraph",
    "validate:template-syntax": "node scripts/linting/validate-template-syntax.js",
    "spellcheck": "cspell --no-progress --show-context --config ./cspell.config.json",
    "quality:check": "pnpm test && pnpm spellcheck && pnpm format:check && pnpm format:check:html && pnpm validate:all",
    "og:check": "node scripts/og-check/cli.js",
    "cms:clean": "node scripts/cms/_clean.js",
    "cms:scan": "node --env-file-if-exists=.env.local scripts/cms/_scan.js",
    "cms:build": "node --env-file-if-exists=.env.local scripts/cms/_build.js",
    "cms:watch": "node --env-file-if-exists=.env.local scripts/cms/_watch.js",
    "cms:validate": "node --env-file-if-exists=.env.local scripts/cms/_validate.js",
    "images:generate": "node scripts/cms/_generate-images.js",
    "images:cleanup": "node scripts/cms/_cleanup-images.js",
    "build:assets": "node scripts/build-assets.js",
    "verify:dist": "node scripts/verify-dist.cjs",
    "check:favicons": "node scripts/check-favicons.js",
    "clear:cache": "rm -rf .parcel-cache dist .vite node_modules/.vite",
    "clear:deps": "rm -rf node_modules pnpm-lock.yaml",
    "clear": "pnpm clear:cache && pnpm clear:deps",
    "reset": "pnpm clear && pnpm install",
    "dev:cms": "pnpm cms:clean && pnpm cms:build && pnpm cms:watch",
    "dev": "vite dev",
    "build": "pnpm cms:clean && pnpm images:generate && pnpm cms:build && pnpm format:build && vite build && pnpm build:assets && pnpm verify:dist",
    "prepare": "node .husky/install.mjs",
    "prepush:check": "pnpm validate:template-syntax && pnpm spellcheck && pnpm check:favicons && pnpm format:check:css && pnpm test && CMS_DISABLE_SCHEDULED_DRAFT_PROMPTS=1 pnpm build && pnpm validate:opengraph:dist && pnpm validate:links:dist && node scripts/linting/validate-a11y.js dist && pnpm validate:security",
    "preview": "vite preview",
    "start": "pnpm dev",
    "rel:major": "node scripts/release.js major",
    "rel:minor": "node scripts/release.js minor",
    "rel:patch": "node scripts/release.js patch"
  },
  "browserslist": "last 2 versions, not dead",
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "1.59.1",
    "cli-real-favicon": "0.0.9",
    "cspell": "10.0.0",
    "gray-matter": "4.0.3",
    "husky": "9.1.7",
    "jsdom": "29.1.0",
    "marked": "18.0.2",
    "pnpm": "10.33.2",
    "postcss": "8.5.12",
    "postcss-combine-media-query": "2.1.0",
    "prettier": "3.8.3",
    "sharp": "0.34.5",
    "vite": "8.0.10",
    "vite-plugin-static-copy": "4.1.0",
    "web-vitals": "5.2.0"
  },
  "engines": {
    "node": ">= 22.0.0",
    "pnpm": ">= 10.33.2"
  }
}
