{
  "name": "dout.dev",
  "version": "0.1.0-alpha.0",
  "description": "The DoUtDev Blog - Static site generator with custom CMS and template engine",
  "repository": "git@github.com:pixu1980/dout-dev.git",
  "author": "Emiliano \"Pixu\" Pisu",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test \"**/*test.js\"",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-exclude='**/*.test.js' \"**/*test.js\"",
    "test:watch": "node --test --watch \"**/*test.js\"",
    "lint": "node scripts/lint.js",
    "format": "node scripts/format.js",
    "format:check": "node scripts/format-check.js",
    "format:html": "node scripts/linting/format-html.js",
    "format:css": "pnpm -s prettier --write \"src/styles/**/*.css\"",
    "format:check:css": "pnpm -s prettier --check \"src/styles/**/*.css\"",
    "format:generated": "pnpm -s prettier --write \"tests/example/*.html\" && pnpm -s biome format \"scripts/**/*.js\" \"tests/**/*.cjs\"",
    "format:check:html": "node scripts/linting/format-check-html.js",
    "validate:html": "node scripts/linting/validate-html.js",
    "validate:structure": "node scripts/linting/validate-structure.js",
    "validate:links": "node scripts/linting/validate-links.js",
    "validate:a11y": "node scripts/linting/validate-a11y.js",
    "validate:all": "pnpm validate:html && pnpm validate:structure && pnpm validate:links && pnpm validate:a11y",
    "quality:check": "pnpm test && pnpm format:check && pnpm format:check:html && pnpm validate:all",
    "cms:clean": "node scripts/cms/clean.js",
    "cms:scan": "node scripts/cms/scan.js",
    "cms:build": "node scripts/cms/build.js",
    "cms:watch": "node scripts/cms/watch.js",
    "cms:validate": "node scripts/cms/validate.js",
    "images:generate": "node scripts/cms/generate-images.js",
    "build:assets": "node scripts/build-assets.js",
    "check:favicons": "node scripts/check-favicons.js",
    "clear:cache": "rm -rf .parcel-cache dist .vite node_modules/.vite",
    "clear:deps": "rm -rf node_modules pnpm-lock.yaml",
    "clear": "pnpm clear:cache && pnpm clear:deps",
    "reset": "pnpm clear && pnpm install",
    "dev:cms": "pnpm cms:clean && pnpm cms:build && pnpm cms:watch",
    "dev": "vite dev",
    "build": "pnpm cms:clean && pnpm images:generate && pnpm cms:build && vite build && pnpm build:assets",
    "preview": "vite preview",
    "start": "pnpm dev"
  },
  "browserslist": "last 2 versions, not dead",
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "cli-real-favicon": "^0.0.9",
    "gray-matter": "^4.0.3",
    "html-minifier": "^4.0.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "marked": "^16.2.1",
    "pnpm": "^10.15.1",
    "postcss": "^8.5.6",
    "postcss-combine-media-query": "^2.0.0",
    "prettier": "^3.6.2",
    "sharp": "^0.34.3",
    "vite": "^7.1.4",
    "vite-plugin-static-copy": "^3.1.2",
    "web-vitals": "^5.1.0"
  },
  "engines": {
    "node": ">= 22.0.0",
    "pnpm": ">= 10.15.1"
  }
}
